# Database (primary — Prisma / ERP per AI_CAMBRIDGE_SCHOOL_CONTEXT.md)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
# Optional: Supabase-style direct connection for migrations
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# Optional: MongoDB Atlas (NOT wired to Prisma in this repo yet).
# If the password contains @ # : / ? etc., URL-encode them (e.g. @ → %40).
# Example pattern: mongodb+srv://USER:ENCODED_PASSWORD@cluster.mongodb.net/DATABASE_NAME?appName=App
# MONGODB_URI=

# Auth
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Supabase (client — browser-safe only)
NEXT_PUBLIC_SUPABASE_URL=
# New Supabase projects: "publishable" key (either this OR anon below)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Legacy JWT "anon" key — same role as publishable; use one or the other
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — never NEXT_PUBLIC_* — admin / RLS bypass where explicitly allowed
SUPABASE_SERVICE_ROLE_KEY=

# AI — Primary
ANTHROPIC_API_KEY=

# AI — Cost Routing
OPENROUTER_API_KEY=

# Payments
JAZZCASH_MERCHANT_ID=
JAZZCASH_PASSWORD=
JAZZCASH_INTEGRITY_SALT=
EASYPAISA_ACCOUNT_NUM=
EASYPAISA_API_KEY=

# WhatsApp
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_ID=

# SMS Fallback
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Video
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=

# Email
RESEND_API_KEY=

# Redis
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# Security
ENCRYPTION_KEY=
JWT_SECRET=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
APP_ENV=development

# CORS (optional — comma-separated extra origins for Expo web / staging)
# CORS_EXTRA_ORIGIN=

# OpenClaw Gateway (API server + workers only — never expose to browser)
OPENCLAW_GATEWAY_URL=http://localhost:18789
OPENCLAW_GATEWAY_TOKEN=
# Signed requests from Gateway → Express tool callbacks
# OPENCLAW_INTERNAL_WEBHOOK_SECRET=

PORT=4000
