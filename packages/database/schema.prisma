// Core ERP slice for live rollout + CSV import. Expand → Section 6.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  SCHOOL_ADMIN
  PRINCIPAL
  VICE_PRINCIPAL
  COORDINATOR
  CLASS_TEACHER
  SUBJECT_TEACHER
  ACCOUNTANT
  LIBRARIAN
  TRANSPORT_MANAGER
  STUDENT
  PARENT
}

model School {
  id         String   @id @default(cuid())
  name       String
  slug       String   @unique
  city       String   @default("Karachi")
  province   String   @default("SINDH")
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  users         User[]
  students      Student[]
  parents       Parent[]
  fee_structure FeeStructure[]
  fee_vouchers  FeeVoucher[]
}

model User {
  id          String   @id @default(cuid())
  school_id   String
  phone       String
  email       String?
  role        Role
  full_name   String
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  school  School   @relation(fields: [school_id], references: [id])
  student Student?
  parent  Parent?

  @@unique([school_id, phone])
  @@index([school_id, role])
}

model Parent {
  id           String  @id @default(cuid())
  user_id      String  @unique
  school_id    String
  whatsapp_number String?

  user     User      @relation(fields: [user_id], references: [id])
  school   School    @relation(fields: [school_id], references: [id])
  children Student[]

  @@index([school_id])
}

model Student {
  id            String  @id @default(cuid())
  user_id       String  @unique
  school_id     String
  parent_id     String?
  admission_no  String
  grade_label   String
  section_label String?

  user         User          @relation(fields: [user_id], references: [id])
  school       School        @relation(fields: [school_id], references: [id])
  parent       Parent?       @relation(fields: [parent_id], references: [id])
  fee_vouchers FeeVoucher[]

  @@unique([school_id, admission_no])
  @@index([school_id])
}

model FeeStructure {
  id             String   @id @default(cuid())
  school_id      String
  fee_head       String
  amount         Decimal  @db.Decimal(12, 2)
  frequency      String   @default("MONTHLY")
  effective_from DateTime @default(now())
  is_active      Boolean  @default(true)

  school School @relation(fields: [school_id], references: [id])

  @@index([school_id])
}

model FeeVoucher {
  id              String   @id @default(cuid())
  school_id       String
  student_id      String
  challan_number  String?  @unique
  month           Int
  year            Int
  gross_amount    Decimal  @db.Decimal(12, 2)
  discount_amount Decimal  @default(0) @db.Decimal(12, 2)
  net_amount      Decimal  @db.Decimal(12, 2)
  due_date        DateTime
  status          String   @default("PENDING")
  generated_at    DateTime @default(now())

  school  School  @relation(fields: [school_id], references: [id])
  student Student @relation(fields: [student_id], references: [id])

  @@unique([school_id, student_id, month, year])
  @@index([school_id])
}
