{
  "name": "ai-cambridge-school",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "web": "npm run dev --workspace=web",
    "web:build": "npm run build --workspace=web",
    "web:start": "npm run start --workspace=web",
    "api": "npm run dev --workspace=api",
    "api:build": "npm run build --workspace=api",
    "api:start": "npm run start --workspace=api",
    "db:generate": "npm run generate --workspace=@ai-cambridge-school/database",
    "db:push": "npm run db:push --workspace=@ai-cambridge-school/database",
    "import:legacy": "tsx scripts/import-legacy-csv.ts",
    "lint": "npm run lint --workspaces --if-present",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css,md}": "prettier --write"
  },
  "devDependencies": {
    "csv-parse": "^5.6.0",
    "dotenv": "^16.4.7",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.4.2",
    "tsx": "^4.19.3"
  },
  "dependencies": {
    "@ai-cambridge-school/database": "*"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
